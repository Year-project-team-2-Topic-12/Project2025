# Copy this file to .env and adjust values for your machine:
#   cp .env.example .env
# (bootstrap.sh does this automatically on first run if .env is missing.)

# ---------- Paths ----------
MODELS_PATH='models/'
DATA_PATH='data/'
RESULTS_PATH='results/'
DATA_ROOT='MURA-v1.1-resized-224x224'
IMAGE_SIZE='224'

# ---------- Classic ML ----------
SELECTED_MODEL='hog_pca_poly_logreg'
# SELECTED_MODEL='hog_pca_poly_logreg_pics'

# ---------- Service ----------
ADMIN_PASSWORD='admin'
LOG_FILE='logs/ml_service.log'
LOG_LEVEL='INFO'
SECRET_KEY='SUPER_SECRET_KEY_CHANGE_ME'
SEED=42

# ---------- MLflow model registry ----------
MLFLOW_TRACKING_URI='http://localhost:5050'
MLFLOW_MODEL_NAME='mura_dinov2_transformer'
MLFLOW_MODEL_ALIAS='prd'
MLFLOW_MODEL_VERSION='2'
MLFLOW_MODEL_URI=''

# ---------- DINOv2 predictor ----------
MURA_DINO_IMAGE_SIZE='448'
MURA_DINO_DEFAULT_THRESHOLD='0.5'
MURA_DINO_THRESHOLD=''
MURA_DINO_DEFAULT_ANATOMY='XR_SHOULDER'
MURA_DINO_BATCH_SIZE='16'
# Device for inference: 'auto' (CUDA if available, else CPU), 'cuda' or 'cpu'.
MURA_DINO_DEVICE='auto'
